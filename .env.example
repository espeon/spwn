# spwn environment configuration
# copy to .env and fill in the required values

# ── postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=spwn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── control-plane ─────────────────────────────────────────────────────────────

# required
INVITE_CODE=changeme
GATEWAY_SECRET=changeme

# optional — defaults shown
# LISTEN_ADDR=0.0.0.0:3019
# GRPC_LISTEN_ADDR=0.0.0.0:5000
# DATABASE_URL=postgres://postgres:changeme@postgres:5432/spwn
# CADDY_URL=http://caddy:2019
# CADDY_REGION_URLS=us-east=http://caddy-us:2019,eu-west=http://caddy-eu:2019
# STATIC_FILES_PATH=/var/lib/spwn/static
# FRONTEND_PATH=/app/frontend/dist
# PUBLIC_URL=https://spwn.run
# SESSION_TTL_SECS=604800
# SSH_GATEWAY_ADDR=localhost:2222

# ── ssh-gateway ───────────────────────────────────────────────────────────────

# optional — defaults shown
# SSH_GATEWAY_LISTEN_ADDR=0.0.0.0:2222
# SSH_GATEWAY_HOST_KEY_PATH=/var/lib/spwn/gateway_host_key
# CONTROL_PLANE_HTTP_URL=http://control-plane:3019

# ── host-agent (not part of compose — runs on bare metal) ────────────────────

# required
# AGENT_PUBLIC_ADDR=http://<host-ip>:4000
# CONTROL_PLANE_URL=http://<control-plane-ip>:5000
# KERNEL_PATH=/var/lib/spwn/vmlinux
# IMAGES_DIR=/var/lib/spwn/images

# optional — defaults shown
# AGENT_LISTEN_ADDR=0.0.0.0:4000
# OVERLAY_DIR=/var/lib/spwn/overlays
# SNAPSHOT_DIR=/var/lib/spwn/snapshots
# JAILER_CHROOT_BASE=/srv/jailer
# FIRECRACKER_BIN=/usr/local/bin/firecracker
# JAILER_BIN=/usr/local/bin/jailer
# SNAPSHOT_LISTEN_ADDR=0.0.0.0:4001
# SNAPSHOT_PUBLIC_ADDR=http://<host-ip>:4001
# AGENT_SECRET=
# JAILER_UID=   # auto-resolved from spwn-vm user if unset
# JAILER_GID=   # auto-resolved from spwn-vm group if unset
# PLATFORM_KEY_PATH=/var/lib/spwn/platform_key
